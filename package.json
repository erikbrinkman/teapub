{
  "name": "teapub",
  "version": "4.0.0",
  "description": "generate epubs using typescript",
  "keywords": [
    "epub",
    "ebook",
    "epub-generator",
    "typescript",
    "javascript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/erikbrinkman/teapub.git"
  },
  "homepage": "https://erikbrinkman.github.io/teapub/",
  "author": {
    "name": "Erik Brinkman",
    "email": "erik.brinkman@gmail.com"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.19"
  },
  "unpkg": "dist/teapub.esm.min.js",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "scripts": {
    "fmt": "biome format --write",
    "lint": "tsc && biome check && typedoc --emit none",
    "doc": "typedoc",
    "export": "tsc -p tsconfig.build.json && bun build src/index.ts --minify --outfile dist/teapub.esm.min.js",
    "prepack": "bun lint && bun test --coverage && bun export"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "leven": "^4.1.0",
    "parse5": "^8.0.0",
    "preact": "^10.29.0",
    "preact-render-to-string": "^6.6.6",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/bun": "^1.3.10",
    "lorem-ipsum": "^2.0.8",
    "sharp": "^0.35.3",
    "typedoc": "^0.28.17",
    "typescript": "~5.9.3"
  }
}
